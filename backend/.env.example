# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/secure_gallery

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password Security
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Rate Limiting
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_ATTEMPTS_WINDOW_MINUTES=15
UPLOAD_RATE_LIMIT=10

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Steganography Detection
STEGANOGRAPHY_THRESHOLD=0.7
ENABLE_LSB_ANALYSIS=true
ENABLE_HISTOGRAM_ANALYSIS=true
ENABLE_EOF_ANALYSIS=true

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
